# XVision Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Backend API ──────────────────────────────────────────
# URL of the deployed Python backend (Railway / Render / etc.)
# Used in any server-side API calls or client-side fetch calls.
# Example: https://xvision-api.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Optional ─────────────────────────────────────────────
# Set to "true" to enable the session API endpoints (coming soon)
# NEXT_PUBLIC_ENABLE_SESSIONS=false
